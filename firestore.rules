rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read their own profile.
    // All writes go through the server (Admin SDK bypasses these rules).
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Uploads are readable only by the owning user.
    match /uploads/{uploadId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.firebase_uid;
      allow write: if false;
    }

    // Decks are readable only by the owning user.
    match /decks/{deckId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.firebase_uid;
      allow write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
