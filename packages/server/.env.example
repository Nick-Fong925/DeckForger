PORT=8080

# Firebase
FIREBASE_PROJECT_ID=

# Local dev: point to your service account JSON file (gitignored via *firebase-adminsdk*.json)
GOOGLE_APPLICATION_CREDENTIALS=./your-project-firebase-adminsdk-xxxx.json

# Production (Cloud Run): paste the full service account JSON as a single line instead
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Google Cloud Storage (Phase 7 — GCP migration)
GCS_BUCKET_NAME=
GCS_SERVICE_ACCOUNT_JSON=

# Webhook secret (shared with Python jobs)
WEBHOOK_SECRET=
