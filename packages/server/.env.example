PORT=8080

# Firebase
FIREBASE_PROJECT_ID=

# Local dev: point to your service account JSON file (gitignored via *firebase-adminsdk*.json)
GOOGLE_APPLICATION_CREDENTIALS=./your-project-firebase-adminsdk-xxxx.json

# Production (Cloud Run): paste the full service account JSON as a single line instead
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Anthropic (used by the generator Python job)
ANTHROPIC_API_KEY=
# Optional: override the model used for card generation (default: claude-haiku-4-5-20251001)
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Google Cloud Storage (Phase 7 — GCP migration)
GCS_BUCKET_NAME=
GCS_SERVICE_ACCOUNT_JSON=

# Webhook secret (shared with Python jobs) — use a long random string
WEBHOOK_SECRET=

# Base URL the Python jobs call back to (defaults to http://localhost:8080)
SERVER_URL=http://localhost:8080
